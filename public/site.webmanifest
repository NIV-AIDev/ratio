	"Resources": {
		"DBInstance": {
			"Type": "AWS::DocDB::DBInstance",
			"Properties": {
				"DBInstanceClass": "<String>",
				"DBClusterIdentifier": "<String>"
			}
		},
		"WarmPool": {
			"Type": "AWS::AutoScaling::WarmPool",
			"Properties": {
				"AutoScalingGroupName": "<String>"
			}
		}
	}
}